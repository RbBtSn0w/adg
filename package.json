{
  "name": "@rbbtsn0w/adg",
  "version": "0.1.0-alpha.1",
  "description": "Agent Directory Group (ADG) toolkit — two domains: plugins and skills.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "adg": "./bin/adg.ts"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "adg": "node ./bin/adg.ts",
    "test": "node --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run typecheck"
  },
  "files": [
    "bin",
    "src",
    "schemas",
    "vendor",
    "docs"
  ],
  "comment:dependencies": "Runtime deps below are required only by the vendored skills CLI (vendor/skills). ADG's own plugins code has zero runtime deps.",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@vercel/detect-agent": "^1.2.3",
    "picocolors": "^1.0.0",
    "simple-git": "^3.0.0",
    "xdg-basedir": "^5.1.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.0.0",
    "semantic-release": "^25.0.5",
    "typescript": "^5.6.0"
  }
}
