{
  "name": "@rbbtsn0w/adg",
  "version": "0.1.0-beta.2",
  "description": "Agent Directory Group (ADG) toolkit — two domains: plugins and skills.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RbBtSn0w/adg.git"
  },
  "homepage": "https://github.com/RbBtSn0w/adg#readme",
  "bugs": {
    "url": "https://github.com/RbBtSn0w/adg/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "adg": "dist/bin/adg.js"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "adg": "node ./bin/adg.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json --noCheck",
    "test": "node --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run typecheck",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "schemas",
    "vendor",
    "docs"
  ],
  "comment:dependencies": "Runtime deps below are required only by the vendored skills CLI (vendor/skills). ADG's own plugins code has zero runtime deps.",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@vercel/detect-agent": "^1.2.3",
    "picocolors": "^1.0.0",
    "simple-git": "^3.0.0",
    "xdg-basedir": "^5.1.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.0.0",
    "semantic-release": "^25.0.5",
    "typescript": "^5.6.0"
  }
}
