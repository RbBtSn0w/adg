# Dependencies
node_modules/

# Logs (covers npm/yarn/pnpm debug logs too)
*.log

# macOS
.DS_Store

# Environment / secrets
.env
.env.*
!.env.example

# TypeScript / tooling output
*.tsbuildinfo
coverage/

# Build output (regenerated by `npm run build` / prepack before publish)
dist/

# npm pack tarballs
*.tgz

# Editors
.idea/
*.swp

# Generated Claude marketplace export for the in-repo reference store.
# The Codex export (plugins/marketplace.json) is tracked; the Claude export is
# regenerated by `adg plugins add|update` on every run, so it is not committed.
# Anchored so the per-plugin .claude-plugin/ manifests stay tracked.
/plugins/.claude-plugin/

# Local Claude Code workspace settings (per-machine, not shared).
/.claude/
plugins/